# ======================================================
# РеверсМаркет — Environment Variables
# ======================================================
# Скопируйте этот файл в .env и заполните значениями:
#   cp env.example .env
#
# НИКОГДА не коммитьте .env в git!
# Для продакшена (Vercel) укажите эти переменные в Settings → Environment Variables.
# ======================================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Или одно имя переменной, как в Supabase Dashboard → Settings → API:
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Локально включить маршрут /seed-data в production-сборке (по умолчанию только dev)
# VITE_ENABLE_SEED=true

# Публичный URL сайта для OG (при необходимости)
# VITE_SITE_URL=https://ваш-домен.ru

# GitHub Pages (project site): путь как в URL, со слэшем в конце, например /RevMarket/
# В CI уже задано в .github/workflows; для ручной сборки: set VITE_BASE_PATH и npm run build

# Supabase SMS Webhook Configuration (для Vercel)
# Эти переменные нужны только для webhook (sms-webhook/)
SUPABASE_SMS_SECRET=your_supabase_sms_secret
# Получите этот секрет в Supabase Dashboard → Authentication → Settings → Phone Auth → SMS Hook Secret

# SMS Provider Configuration (для Vercel webhook)
# Варианты: exolve, smsc, smsaero, esputnik
SMS_PROVIDER=exolve
SMS_API_KEY=your_sms_api_key
SMS_SENDER=РЕВЕРС МАРК

# Для SMSC.ru (smsc) также нужен логин:
# Получите логин и пароль в личном кабинете SMSC.ru:
# https://smsc.ru/ → Вход в систему
SMSC_LOGIN=your_smsc_login
# Примечание: SMS_API_KEY для SMSC.ru - это пароль от аккаунта SMSC.ru

# Для SMS Aero (smsaero) также нужен email:
# Получите email и API ключ в личном кабинете SMS Aero:
# https://smsaero.ru/cabinet/ → Настройки → API и SMPP
SMS_AERO_EMAIL=your_email@smsaero.ru
# Примечание: SMS_API_KEY для SMS Aero - это сгенерированный API ключ (пароль для API)

# --- Edge Function send-offer-notification (секреты в Supabase Dashboard → Edge Functions) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SITE_URL=https://ваш-домен.ru
# RESEND_API_KEY=re_...
# RESEND_FROM=РеверсМаркет <notify@ваш-домен.ru>
# TELEGRAM_BOT_TOKEN=
